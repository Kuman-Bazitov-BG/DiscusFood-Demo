# ─────────────────────────────────────────────────────────────
#  Discus Fish — DEMO CLIENT environment (front-end, Vite)
#  Only PUBLIC values here. Vite exposes every VITE_* var to the
#  browser, so never put secrets in this file. Copy to .env.
# ─────────────────────────────────────────────────────────────

# Show the "Demo / Test mode" banner + simulated-payment notice.
# Set to "true" for the public demo deployment. Leave unset in production.
VITE_DEMO_MODE=true

# Stripe TEST publishable key (Developers > API keys). Public by design.
# Demo uses Stripe test mode — test card 4242 4242 4242 4242.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Checkout runs on a Supabase Edge Function at
#   ${VITE_SUPABASE_URL}/functions/v1/checkout
# so no separate API URL is needed for the demo. (Legacy Express var kept
# for local fallback only.)
VITE_API_URL=

# Demo Supabase project URL + publishable (anon) key. Public by design — RLS protects data.
VITE_SUPABASE_URL=https://your-demo-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
